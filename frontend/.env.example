# ============================================================
# LankaCommerce Cloud — Frontend Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
#
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the
# browser. All other variables are server-side only.
# ============================================================

# ------------------------------------------------------------
# Next.js Public Variables (Exposed to Browser)
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LankaCommerce
NEXT_PUBLIC_CURRENCY=LKR
NEXT_PUBLIC_CURRENCY_SYMBOL=₨
NEXT_PUBLIC_TIMEZONE=Asia/Colombo

# ------------------------------------------------------------
# API Configuration (Server-Side Only)
# ------------------------------------------------------------
API_BASE_URL=http://backend:8000/api
API_TIMEOUT=30000

# ------------------------------------------------------------
# Authentication
# ------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------
NEXT_PUBLIC_ENABLE_POS=true
NEXT_PUBLIC_ENABLE_WEBSTORE=true
NEXT_PUBLIC_ENABLE_AI=true
NEXT_PUBLIC_ENABLE_OFFLINE=true

# ------------------------------------------------------------
# Analytics & Monitoring
# ------------------------------------------------------------
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SENTRY_DSN=

# ------------------------------------------------------------
# Payment Integration
# ------------------------------------------------------------
NEXT_PUBLIC_PAYHERE_MERCHANT_ID=
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=

# ------------------------------------------------------------
# Image Optimization
# ------------------------------------------------------------
NEXT_PUBLIC_IMAGE_DOMAIN=cdn.lankacommerce.lk
NEXT_PUBLIC_CLOUDINARY_CLOUD=

# ------------------------------------------------------------
# Tenant Configuration
# ------------------------------------------------------------
NEXT_PUBLIC_DEFAULT_TENANT=demo
NEXT_PUBLIC_TENANT_PATTERN={tenant}.lankacommerce.lk
