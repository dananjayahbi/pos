# =============================================================================
# LankaCommerce Cloud — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#
#   cp .env.local.example .env.local
#
# NEVER commit .env.local to version control.
#
# NEXT_PUBLIC_ prefix: Exposed to browser (client-side accessible).
# Without prefix:      Server-side only (API routes, middleware, SSR).
# See docs/ENVIRONMENT.md for full documentation.
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL — Client-side API calls (from browser)
#   Used by: fetch hooks, API service layer, product/cart/auth modules
# API_BASE_URL       — Server-side API calls (SSR, API routes, middleware)
# NEXT_PUBLIC_WS_URL — WebSocket connection for real-time features
#   Used by: notifications, live order updates, POS real-time sync
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1        # Browser → Backend
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws               # WebSocket → Backend
API_BASE_URL=http://backend:8000/api/v1                # Server → Backend (Docker network)
API_TIMEOUT=30000                                      # Integer: request timeout (ms)

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL  — Canonical frontend URL
#   Used by: SEO meta tags, OpenGraph, canonical links, sitemap generation
# NEXT_PUBLIC_SITE_NAME — Application display name
#   Used by: page titles, navbar branding, email templates, PWA manifest
# NEXT_PUBLIC_APP_NAME  — Short application name (for PWA, favicons)
#   Used by: PWA manifest short_name, browser tab titles, mobile home screen
NEXT_PUBLIC_SITE_URL=http://localhost:3000              # Canonical frontend URL
NEXT_PUBLIC_SITE_NAME=LankaCommerce Cloud              # Full display name
NEXT_PUBLIC_APP_NAME=LCC                               # Short name (PWA, tabs)
NEXT_PUBLIC_SITE_DESCRIPTION=Multi-tenant SaaS ERP for Sri Lankan SMEs

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# NEXTAUTH_SECRET is REQUIRED in production — generate with: openssl rand -base64 32
NEXT_PUBLIC_AUTH_COOKIE_NAME=lcc_auth                   # Auth cookie name
NEXT_PUBLIC_TOKEN_EXPIRY_BUFFER=60                     # Integer: seconds before expiry to refresh
NEXTAUTH_URL=http://localhost:3000                     # NextAuth callback URL
NEXTAUTH_SECRET=                                       # SECRET — random base64 string

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Boolean strings: "true" / "false"
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_AI_FEATURES=false
NEXT_PUBLIC_ENABLE_WEBSTORE=true
NEXT_PUBLIC_ENABLE_POS=true
NEXT_PUBLIC_ENABLE_OFFLINE=true
NEXT_PUBLIC_DEBUG=false

# -----------------------------------------------------------------------------
# Third-Party Services (Public Keys Only)
# -----------------------------------------------------------------------------
# Analytics — Google Analytics 4
#   Used by: analytics provider, page view tracking, event tracking
#   Enabled when: NEXT_PUBLIC_ENABLE_ANALYTICS=true (disabled in development)
NEXT_PUBLIC_GA_TRACKING_ID=                            # G-XXXXXXXXXX

# Error Tracking — Sentry
NEXT_PUBLIC_SENTRY_DSN=                                # https://xxx@sentry.io/yyy

# Payment Integration — PayHere (Sri Lanka)
NEXT_PUBLIC_PAYHERE_MERCHANT_ID=                       # PayHere sandbox/live merchant ID

# Payment Integration — Stripe
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=                          # pk_test_... or pk_live_...

# -----------------------------------------------------------------------------
# Sri Lanka Localization
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEFAULT_LOCALE=en-LK                       # BCP 47 locale tag
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Colombo              # IANA timezone
NEXT_PUBLIC_DEFAULT_CURRENCY=LKR                       # ISO 4217 currency code
NEXT_PUBLIC_CURRENCY_SYMBOL=Rs.                        # Display symbol

# -----------------------------------------------------------------------------
# Tenant Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEFAULT_TENANT=demo                        # Default tenant slug
NEXT_PUBLIC_TENANT_PATTERN={tenant}.lankacommerce.lk   # Tenant URL pattern

# -----------------------------------------------------------------------------
# Image / CDN Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_IMAGE_DOMAIN=cdn.lankacommerce.lk          # next/image allowed domain
NEXT_PUBLIC_CLOUDINARY_CLOUD=                          # Cloudinary cloud name (if used)
