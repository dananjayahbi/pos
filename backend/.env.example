# =============================================================================
# LankaCommerce Cloud — Backend Environment Variables
# =============================================================================
# Copy this file to .env or .env.local and fill in the values:
#
#   cp .env.example .env          # primary (loaded second, higher priority)
#   cp .env.example .env.local    # alternative (loaded first)
#
# NEVER commit .env or .env.local to version control.
#
# Variable names must match those defined in config/env.py.
# See config/env.py for defaults, casting helpers, and loading order.
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core Settings
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string   # REQUIRED in production — use a long random string
DEBUG=True                                             # Boolean: True/False — MUST be False in production
ALLOWED_HOSTS=localhost,127.0.0.1                      # Comma-separated list of hostnames
DJANGO_SETTINGS_MODULE=config.settings.local           # config.settings.{local,production,test}
LOG_LEVEL=DEBUG                                        # DEBUG, INFO, WARNING, ERROR, CRITICAL

# -----------------------------------------------------------------------------
# Database Settings
# -----------------------------------------------------------------------------
# DATABASE_URL is the canonical connection string (used by dj-database-url).
# Individual DB_* vars are used by local.py for granular control.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lankacommerce_dev
DB_ENGINE=django.db.backends.postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lankacommerce_dev
DB_USER=lcc_user
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Redis / Cache Settings
# -----------------------------------------------------------------------------
# URL format: redis://[:password@]host:port/db_number
REDIS_URL=redis://localhost:6379/0                     # General Redis connection
CACHE_URL=redis://localhost:6379/1                     # Django cache backend

# -----------------------------------------------------------------------------
# Celery Settings
# -----------------------------------------------------------------------------
# URL format: redis://host:port/db_number (or amqp:// for RabbitMQ)
CELERY_BROKER_URL=redis://localhost:6379/0             # Message broker
CELERY_RESULT_BACKEND=redis://localhost:6379/0         # Task result storage

# -----------------------------------------------------------------------------
# Multi-Tenancy Settings
# -----------------------------------------------------------------------------
TENANT_MODEL=tenants.Tenant
TENANT_DOMAIN_MODEL=tenants.Domain
PUBLIC_SCHEMA_NAME=public

# -----------------------------------------------------------------------------
# Email Settings
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@lankacommerce.lk

# -----------------------------------------------------------------------------
# File Storage Settings
# -----------------------------------------------------------------------------
DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=lcc-media-dev
AWS_S3_REGION_NAME=ap-south-1

# -----------------------------------------------------------------------------
# Sri Lanka Localization Settings
# -----------------------------------------------------------------------------
DEFAULT_CURRENCY=LKR
TIME_ZONE=Asia/Colombo
LANGUAGE_CODE=en
SUPPORTED_LANGUAGES=en,si,ta

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
SECURE_SSL_REDIRECT=False

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Sentry (optional — production only)
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
